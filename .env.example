# ---- Core ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://sync:sync@localhost:5432/syncdb

# ---- Sync scheduling (M3) ----
# Cron expression for the in-process scheduler. Default: every 15 minutes.
SYNC_CRON=*/15 * * * *
# Safety lookback applied to incremental cursors to avoid boundary misses (seconds).
SYNC_LOOKBACK_SECONDS=60
# Enable/disable the in-process scheduler (off in tests).
SYNC_SCHEDULER_ENABLED=true

# ---- Admin endpoints (M8) ----
# Bearer token protecting /admin/* and /internal/sync. Generate a random value.
ADMIN_TOKEN=change-me

# ---- Stripe (M2 / M7) ----
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- HubSpot (M6 / M7) ----
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_WEBHOOK_SECRET=

# ---- Google Calendar (M5 / M7) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
